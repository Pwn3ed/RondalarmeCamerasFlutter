rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAuthEnabled() {
      return request.auth != null && userDoc().disabled != true;
    }
    function isAdmin() {
      return isAuthEnabled() && userDoc().role == 'admin';
    }
    function canToggleCameraPublic() {
      return userDoc().get('canToggleCameraPublic', true) == true;
    }

    match /users/{uid} {
      allow read: if request.auth != null
                  && (request.auth.uid == uid || isAdmin());
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
                 || (request.auth.uid == uid
                     && (
                          request.resource.data.diff(resource.data).changedKeys()
                               .hasOnly(['mustChangePassword', 'lastLoginAt'])
                       || (
                            request.resource.data.canToggleCameraPublic == false
                            && request.resource.data.diff(resource.data).changedKeys()
                                 .hasOnly([
                                   'canToggleCameraPublic',
                                   'publicToggleBlockedReason'
                                 ])
                          )
                     ));
    }

    match /cameras/{id} {
      function hasCameraAccess(data) {
        return request.auth.uid in data.get('assignedUserIds', [])
            || (data.keys().hasAny(['ownerId'])
                && data.ownerId == request.auth.uid);
      }

      allow read: if isAuthEnabled() && (
                      isAdmin()
                   || hasCameraAccess(resource.data)
                   || resource.data.isPublic == true);
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
                 || (isAuthEnabled()
                     && hasCameraAccess(resource.data)
                     && canToggleCameraPublic()
                     && request.resource.data.assignedUserIds
                          == resource.data.get('assignedUserIds', [])
                     && request.resource.data.get('ownerId', null)
                          == resource.data.get('ownerId', null)
                     && request.resource.data.diff(resource.data).changedKeys()
                          .hasOnly(['isPublic']));
    }

    match /sessions/{sid} {
      allow read: if isAuthEnabled()
                  && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(
                         ['uid', 'deviceId', 'platform', 'createdAt', 'lastSeenAt']);
      allow update: if isAdmin()
                 || (resource.data.uid == request.auth.uid
                     && request.resource.data.diff(resource.data).changedKeys()
                          .hasOnly(['lastSeenAt', 'endedAt', 'endReason']));
      allow delete: if isAdmin();
    }

    match /audit_logs/{id} {
      allow read: if isAdmin()
                  || (isAuthEnabled()
                      && resource.data.actorUid == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.actorUid == request.auth.uid
                    && request.resource.data.keys().hasAll(
                         ['actorUid', 'action', 'createdAt']);
      allow update, delete: if false;
    }
  }
}
